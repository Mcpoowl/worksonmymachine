---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FeaturePost from '../components/FeaturePost.astro';
import NowCard from '../components/NowCard.astro';
import PostRow from '../components/PostRow.astro';
import ThemeSwitcherPrompt from '../components/ThemeSwitcherPrompt.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featurePost = posts[0];
const postList = posts.slice(1, 8);
const earliestYear = Math.min(...posts.map((p) => p.data.date.getFullYear()));

const daysAgo = featurePost
  ? Math.round((Date.now() - featurePost.data.date.getTime()) / 86400000)
  : 0;
const updatedText =
  daysAgo === 0 ? 'today' : daysAgo === 1 ? 'yesterday' : `${daysAgo} days ago`;

const nowEntries = await getCollection('now');
const now = nowEntries[0]?.data;
---

<Base>
  <section class="hero">
    <div class="theme-poke" aria-hidden="true">
      <span class="theme-poke__note" data-poke-note>psst — kill the lights ↗</span>
      <svg class="theme-poke__arrow" viewBox="0 0 280 230" preserveAspectRatio="none" fill="none">
        <path d="M 190 178 Q 220 158, 220 138 T 232 102 T 246 66"
              stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <path d="M 238 66 L 246 58 L 254 66"
              stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>
    <h1>
      A notebook for<br />
      things that <em>mostly</em><br />
      work.<span class="aside">*most days</span>
    </h1>
    <div class="intro">
      <p>I dabble in everything that is somewhat related to tech, both professionally and personally. Jack of all trades, master of none. This is where I write it all down, because I can. Expect honest notes on AI tooling, self-hosted infrastructure, and whatever my Home Assistant decided to do at 3am.</p>
      <div class="meta">
        <span class="live">rack is up</span>
        <span>{posts.length} posts</span>
        <span>~14&nbsp;min/wk</span>
      </div>
    </div>
  </section>

  <div class="section-head">
    <h2>Latest</h2>
    <span class="meta">Updated {updatedText}</span>
  </div>

  {featurePost && (
    <FeaturePost
      number={featurePost.data.number}
      date={featurePost.data.date}
      readTime={featurePost.data.readTime}
      kicker={featurePost.data.kicker}
      category={featurePost.data.category}
      title={featurePost.data.title}
      dek={featurePost.data.dek}
      tags={featurePost.data.tags}
      editorNote={featurePost.data.editorNote}
      href={`/posts/${featurePost.id}`}
    />
  )}

  <div class="two-col">
    <ul class="post-list">
      {postList.map((post) => (
        <PostRow
          number={post.data.number}
          date={post.data.date}
          readTime={post.data.readTime}
          category={post.data.category}
          title={post.data.title}
          href={`/posts/${post.id}`}
        />
      ))}
    </ul>

    {now && (
      <NowCard
        writing={now.writing}
        reading={now.reading}
        running={now.running}
        broken={now.broken}
        listening={now.listening}
        coffee={now.coffee}
      />
    )}
  </div>

  <div class="all-posts">
    <span>{posts.length} posts · {earliestYear} — now</span>
    <a href="/archive">Browse the full archive &nbsp;→</a>
  </div>
</Base>
