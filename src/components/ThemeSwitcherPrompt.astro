<div class="theme-switcher-prompt">
  <svg class="arrow" viewBox="0 0 80 200" preserveAspectRatio="none" aria-hidden="true">
    <path d="M 40 0 Q 20 40, 40 80 Q 60 120, 40 160 L 35 180 L 40 170 L 45 180"
          stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <div class="message" data-dark="Press this to feel your eyes burning" data-light="Press this to preserve your retinas"></div>
</div>

<script>
  (function() {
    const message = document.querySelector('.theme-switcher-prompt .message');
    const html = document.documentElement;

    function updateMessage() {
      const theme = html.getAttribute('data-theme');
      const text = theme === 'dark'
        ? message.getAttribute('data-dark')
        : message.getAttribute('data-light');
      message.textContent = text;
    }

    updateMessage();

    // Listen for theme changes
    const observer = new MutationObserver(updateMessage);
    observer.observe(html, { attributes: true, attributeFilter: ['data-theme'] });
  })();
</script>

<style>
  .theme-switcher-prompt {
    position: absolute;
    top: 20px;
    right: -120px;
    width: 180px;
    color: var(--ink-2);
    display: none;
  }

  .arrow {
    width: 80px;
    height: 140px;
    margin-bottom: 12px;
    color: var(--accent);
  }

  .message {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.4;
    color: var(--ink-2);
    animation: subtle-float 3s ease-in-out infinite;
    padding-top: 8px;
  }

  @keyframes subtle-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @media (min-width: 1280px) {
    .theme-switcher-prompt {
      display: block;
    }
  }
</style>
